APP_NAME="Sena Digital"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://api.sena-digital.com
FRONTEND_URL=https://sena-digital.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.your-mail-provider.com
MAIL_PORT=587
MAIL_USERNAME=noreply@sena-digital.com
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@sena-digital.com
MAIL_FROM_NAME="Sena Digital"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# File Upload Configuration
MAX_FILE_SIZE=51200
MAX_FILE_SIZE_MB=50
MAX_MUSIC_SIZE=10240
MAX_MUSIC_SIZE_MB=10

# Global Music Catalog Provider (local/dev)
GLOBAL_MUSIC_PROVIDER_ENABLED=false
GLOBAL_MUSIC_PROVIDER=jamendo
GLOBAL_MUSIC_SYNC_LIMIT=20
GLOBAL_MUSIC_TAGS=
GLOBAL_MUSIC_GENRES=
JAMENDO_CLIENT_ID=
JAMENDO_BASE_URL=https://api.jamendo.com/v3.0/tracks/
JAMENDO_TIMEOUT_SECONDS=20

# Midtrans Payment Gateway Configuration (Sandbox)
MIDTRANS_SERVER_KEY=your-sandbox-server-key-here
MIDTRANS_CLIENT_KEY=your-sandbox-client-key-here
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_IS_SANITIZED=true
MIDTRANS_IS_3DS=true

# Midtrans Callback URLs
MIDTRANS_FINISH_URL=https://www.sena-digital.com/dashboard/overview
MIDTRANS_ERROR_URL=https://www.sena-digital.com/buat-undangan
MIDTRANS_PENDING_URL=https://www.sena-digital.com/buat-undangan

# Midtrans Payment Limits
MIDTRANS_MIN_AMOUNT=10000
MIDTRANS_MAX_AMOUNT=100000000

# Midtrans Token Expiry
MIDTRANS_TOKEN_EXPIRY_HOURS=24
